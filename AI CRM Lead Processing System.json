        0
      ],
      "id": "0280d31d-f597-48c3-862b-8ffabc8b77ed",
      "name": "Edit Fields"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "key",
              "value": "AQ.Ab8RN6LUEy_T0PoKqjB4itVTuypB6nmC2VqPUnK-_faeJqh-7Q"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are an experienced B2B sales qualification assistant.\\n\\nAnalyze the lead message below.\\n\\nExtract the information and estimate how valuable this lead is.\\n\\nRules:\\n- Return ONLY valid JSON.\\n- Do not use markdown.\\n- Budget must be a number.\\n- Employees must be a number.\\n- Lead score must be an integer from 0 to 100.\\n- Priority must be High, Medium, or Low.\\n\\nLead scoring guidelines:\\n- Higher budget increases score.\\n- More employees generally increase score.\\n- Business AI automation requests increase score.\\n- Clear buying intent increases score.\\n\\nReturn exactly:\\n\\n{\\n  \\\"name\\\": \\\"\\\",\\n  \\\"email\\\": \\\"\\\",\\n  \\\"company\\\": \\\"\\\",\\n  \\\"job_title\\\": \\\"\\\",\\n  \\\"employees\\\": 0,\\n  \\\"budget\\\": 0,\\n  \\\"need\\\": \\\"\\\",\\n  \\\"timeline\\\": \\\"\\\",\\n  \\\"priority\\\": \\\"\\\",\\n  \\\"lead_score\\\": 0\\n}\\n\\nLead message:\\n{{$json.lead_message}}\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        416,
        0
      ],
      "id": "7c99198b-38e8-4572-8f9e-0b9fd9eaa67f",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.candidates[0].content.parts[0].text;\n\nconst lead = JSON.parse(text);\n\nreturn [\n  {\n    json: lead\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ],
      "id": "311efd86-6988-48fb-84dc-e9975470d49a",
      "name": "Parse Lead"
    },
    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\n\nconst errors = [];\n\n// Required fields\nif (!lead.name) {\n  errors.push(\"Missing name\");\n}\n\nif (!lead.email) {\n  errors.push(\"Missing email\");\n}\n\nif (!lead.company) {\n  errors.push(\"Missing company\");\n}\n\nif (!lead.need) {\n  errors.push(\"Missing business need\");\n}\n\n// Email validation\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n\nif (!emailRegex.test(lead.email)) {\n  errors.push(\"Invalid email address\");\n}\n\n// Budget validation\nif (typeof lead.budget !== \"number\" || lead.budget < 0) {\n  errors.push(\"Invalid budget\");\n}\n\n// Employees validation\nif (typeof lead.employees !== \"number\" || lead.employees < 1) {\n  errors.push(\"Invalid employee count\");\n}\n\n// Lead score validation\nif (\n  typeof lead.lead_score !== \"number\" ||\n  lead.lead_score < 0 ||\n  lead.lead_score > 100\n) {\n  errors.push(\"Invalid lead score\");\n}\n\n// Priority validation\nconst priorities = [\"High\", \"Medium\", \"Low\"];\n\nif (!priorities.includes(lead.priority)) {\n  errors.push(\"Invalid priority\");\n}\n\nreturn [\n  {\n    json: {\n      ...lead,\n      valid: errors.length === 0,\n      errors\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
