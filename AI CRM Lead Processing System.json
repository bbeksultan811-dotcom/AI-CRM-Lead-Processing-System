              "id": "de813c1a-4885-445d-ab6d-e9b086c3d1e2",
              "name": "lead_message",
              "value": "Hello,  My name is John Smith.  I am the Operations Manager at Swift Logistics.  We have 35 employees.  We are looking to automate customer support, CRM, and invoice processing using AI.  Our estimated budget is around $12,000.  We would like to start next month.  You can contact me at john@example.com.",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
